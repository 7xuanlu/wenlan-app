{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Origin",
  "windows": ["main", "toast", "quick-capture"],
  "permissions": [
    "core:default",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "clipboard-x:default",
    "fs:default",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/wenlan-server", "sidecar": true, "args": true },
        { "name": "binaries/wenlan-mcp", "sidecar": true, "args": true },
        { "name": "binaries/cloudflared", "sidecar": true, "args": true }
      ]
    },
    "shell:allow-kill",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-is-visible",
    "dialog:default",
    "dialog:allow-open",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "notification:allow-is-permission-granted",
    "core:window:allow-set-size",
    "core:window:allow-set-resizable",
    "core:window:allow-set-position",
    "core:window:allow-outer-position",
    "core:window:allow-outer-size",
    "core:window:allow-scale-factor",
    "core:event:default",
    "core:window:allow-available-monitors",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-start-dragging"
  ]
}
